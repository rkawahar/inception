# ===========================================
# Inception - Copy to .env and set values: cp env.example .env
# Replace "yourlogin" with your 42 intra login.
# ===========================================

# Domain (must be login.42.fr - replace yourlogin with your 42 login)
DOMAIN_NAME=yourlogin.42.fr

# Host path for named volumes (must be /home/<your_login>/data)
HOST_DATA_PATH=/home/yourlogin/data

# MariaDB
MYSQL_ROOT_PASSWORD=choose_secure_root_password
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
MYSQL_PASSWORD=choose_secure_db_password

# WordPress administrator (username must NOT contain "admin" or "administrator")
WP_SUPERUSER=superuser
WP_SUPERUSER_PASSWORD=choose_secure_admin_password
WP_SUPERUSER_EMAIL=superuser@example.com

# WordPress second user (author role)
WP_USER=editor
WP_USER_PASSWORD=choose_secure_user_password
WP_USER_EMAIL=editor@example.com
